# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://bjjyiyaevsncybbyhcdf.supabase.co
SUPABASE_PUBLISHABLE_KEY=              # safe for client-side use (Expo app)
SUPABASE_SECRET_KEY=                   # ⚠️ NEVER share in chat — server-side only, bypasses RLS
# JWT signing keys fetched automatically from $SUPABASE_URL/auth/v1/.well-known/jwks.json
DATABASE_URL=                          # Supabase > Settings > Database > Connection string (Transaction mode)

# ── Upstash Redis ─────────────────────────────────────────
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# ── Ravelry OAuth ─────────────────────────────────────────
RAVELRY_CLIENT_ID=
RAVELRY_CLIENT_SECRET=
RAVELRY_REDIRECT_URI=https://bjjyiyaevsncybbyhcdf.supabase.co/auth/v1/callback

# ── Anthropic (abbreviation fallback only) ────────────────
ANTHROPIC_API_KEY=

# ── RevenueCat ────────────────────────────────────────────
REVENUECAT_WEBHOOK_SECRET=

# ── Email ─────────────────────────────────────────────────
RESEND_API_KEY=

# ── App ───────────────────────────────────────────────────
APP_SECRET=                            # 32-byte AES key for encrypting Ravelry tokens
                                       # generate with: openssl rand -hex 32
PORT=8080
ENV=development                        # development | production
